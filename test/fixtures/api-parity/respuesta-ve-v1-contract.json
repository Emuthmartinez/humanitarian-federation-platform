  "parityGates": [
    {
      "id": "read-only-reference-host",
      "description": "Fixture refresh may use public GETs only; authenticated writes and Respuesta VE repo edits are out of scope."
    },
    {
      "id": "public-intake-receipt-redaction",
      "description": "Receipts expose queue status only and never echo raw submissions, private contacts, restricted hints, image data, child details, or identity documents."
    },
    {
      "id": "source-provenance",
      "description": "Every promoted canonical record keeps source and link-back provenance; partners cannot spoof source attribution through request body fields."
    },
    {
      "id": "cursor-freshness",
      "description": "Changes feeds use durable since/nextSince cursors and timestamp-aware updates to prevent stale overwrites."
    },
    {
      "id": "candidate-duplicate-advisory",
      "description": "Matching and grouping output remains advisory until coordinator review; no client should auto-merge, resolve, delete, or collapse identities."
    },
    {
      "id": "badge-scope-not-endorsement",
      "description": "Badges mean verified federation participation and scopes, not government approval or safety endorsement."
    },
    {
      "id": "child-protection-fail-closed",
      "description": "Child-protection cases, whereabouts, caregiver claims, proof artifacts, and case notes stay restricted unless a separate safe public projection is modeled."
    },
    {
      "id": "no-live-private-fixtures",
      "description": "Static fixtures may include public metadata and synthetic shape keys only, never live crisis records, secrets, contacts, exact private coordinates, national IDs, or raw photo hashes."
    }
